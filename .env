# ── ARC Platform — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in values

# App
APP_NAME=ARC
APP_ENV=development
LOG_LEVEL=INFO

# MongoDB
MONGO_URI=mongodb://localhost:27017/arc_db
MONGO_DB_NAME=arc_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Groq (LLM inference)
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Embeddings (local sentence-transformers — no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Cost Control
MAX_TASK_BUDGET_USD=10.0
MAX_SINGLE_LLM_COST_USD=1.0
MAX_STEPS_PER_TASK=100

# RAG
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# File Uploads
MAX_FILE_SIZE_MB=50

# Frontend (only used in docker-compose)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
